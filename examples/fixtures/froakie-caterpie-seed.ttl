# --- Battle layer ---

pkm:Battle_1
    a pkm:Battle ;
    pkm:operatesUnderRuleset pkm:Gen6XY .

pkm:Side_Player
    a pkm:BattleSide ;
    pkm:hasSideIndex 0 .

pkm:Side_Wild
    a pkm:BattleSide ;
    pkm:hasSideIndex 1 .

pkm:Combatant_Froakie
    a pkm:OwnedCombatant ;
    pkm:participatesInBattle     pkm:Battle_1 ;
    pkm:onSide                   pkm:Side_Player ;
    pkm:instantiatesOwnedPokemon pkm:OwnedPokemon_1 ;
    pkm:hasTeamPosition          1 .

pkm:Combatant_Caterpie
    a pkm:TransientCombatant ;
    pkm:participatesInBattle pkm:Battle_1 ;
    pkm:onSide               pkm:Side_Wild ;
    pkm:hasTeamPosition      1 .

# --- Instantaneous layer ---

pkm:Instantaneous_1_0
    a pkm:Instantaneous ;
    pkm:occursInBattle pkm:Battle_1 ;
    pkm:hasTurnIndex  1 ;
    pkm:hasStepIndex  0 .

